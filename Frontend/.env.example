# ============================================
# JOB PORTAL FRONTEND - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and update as needed.
# In Vercel, set this in Settings > Environment Variables

# ============================================
# API CONFIGURATION (REQUIRED)
# ============================================
# This must point to your deployed backend URL
#
# Development: http://localhost:5001
# Production (Render): https://your-backend-name.onrender.com
#
# IMPORTANT:
# - Always include the protocol (http:// or https://)
# - Must match the backend's CORS_ORIGINS setting
# - Check backend logs if you get "No token provided" errors
VITE_API_BASE_URL=https://job-portal-api.onrender.com
