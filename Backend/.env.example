# Copy this file to .env and fill in your values
MONGO_URI=
JWT_SECRET=
PORT=5001
NODE_ENV=production

# Cloudinary
CLOUD_NAME=
CLOUD_API=
API_SECRET=

# Secrets to protect higher privilege accounts
RECRUITER_SECRET=
ADMIN_SECRET=

# CORS Origins (comma-separated URLs for frontend)
# For Render: https://yourdomain.com,https://www.yourdomain.com
CORS_ORIGINS=http://localhost:5175,http://localhost:5173,http://localhost:5174
