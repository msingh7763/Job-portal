# ============================================
# JOB PORTAL BACKEND - ENVIRONMENT VARIABLES
# ============================================
# Copy this file to .env and fill in your values

# ============================================
# CORE CONFIGURATION
# ============================================
NODE_ENV=production
PORT=5001

# ============================================
# DATABASE
# ============================================
# MongoDB Atlas: mongodb+srv://username:password@cluster.mongodb.net/job-portal
# Local MongoDB: mongodb://localhost:27017/job-portal
MONGO_URI=

# ============================================
# AUTHENTICATION & SECURITY
# ============================================
# Generate a secure random string (min 32 characters)
# Example: openssl rand -base64 32
JWT_SECRET=

# Optional: Secrets to protect higher privilege accounts
RECRUITER_SECRET=
ADMIN_SECRET=

# ============================================
# FILE UPLOADS (CLOUDINARY)
# ============================================
# Get these from https://cloudinary.com/console
CLOUD_NAME=
CLOUD_API=
API_SECRET=

# ============================================
# CORS CONFIGURATION (IMPORTANT FOR PRODUCTION)
# ============================================
# Comma-separated list of allowed frontend URLs
# Development: http://localhost:5173,http://localhost:5174,http://localhost:5175
# Production (Vercel): https://your-domain.vercel.app,https://www.your-domain.vercel.app
# NEVER include localhost URLs in production!
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:5175

# ============================================
# EMAIL CONFIGURATION (OPTIONAL - for password reset)
# ============================================
SMTP_EMAIL=
SMTP_PASSWORD=
SMTP_SERVICE=gmail
